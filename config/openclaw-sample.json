{
  "NOTE": "This is a SAMPLE config. Replace API keys with your own. Never commit real keys.",
  "models": {
    "mode": "merge",
    "providers": {
      "zai": {
        "baseUrl": "https://api.z.ai/api/coding/paas/v4",
        "api": "openai-completions",
        "models": [
          {"id": "glm-5", "name": "GLM-5", "reasoning": true, "input": ["text"], "contextWindow": 204800},
          {"id": "glm-4.7", "name": "GLM-4.7", "reasoning": true, "input": ["text"], "contextWindow": 204800}
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "zai/glm-5"
    },
    "list": [
      {"id": "aurix", "model": "custom-ai-sumopod-com/claude-opus-4-6"},
      {"id": "bayan", "model": "custom-ai-sumopod-com/claude-opus-4-6"},
      {"id": "falah", "model": "custom-ai-sumopod-com/claude-sonnet-4-6"}
    ]
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "allowlist",
      "allowFrom": ["+62XXXXXXXXXXX"]
    }
  },
  "skills": {
    "install": {
      "nodeManager": "bun"
    }
  },
  "studio": {
    "NOTE": "Claw3D Studio settings — 3D visual workspace for agent monitoring",
    "enabled": true,
    "port": 3000,
    "gatewayUrl": "ws://localhost:18789",
    "features": {
      "office3d": true,
      "officeBuilder": true,
      "agentChat": true,
      "approvals": true
    },
    "deskAssignments": {
      "moni": "command-center",
      "falah": "trading-desk",
      "aurix": "audit-room",
      "bayan": "research-lab"
    }
  }
}
